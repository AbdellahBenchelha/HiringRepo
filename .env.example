# =============================================================================
#  Environment variables — copy to .env.local and fill in. NEVER commit secrets.
# =============================================================================

# Telegram notifications for the application form.
# 1. Create a bot with @BotFather and copy the token below.
# 2. Send any message to your new bot (or add it to a group).
# 3. Open https://api.telegram.org/bot<TOKEN>/getUpdates and copy the chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Interview links (optional).
# PUBLIC_BASE_URL  — public address of the site, used to build the interview
#                    link in the Telegram message (e.g. https://careers.yoursite.com).
#                    If empty, the request host is used automatically.
# INTERVIEW_TOKEN_SECRET — secret used to sign interview links. If empty, the
#                    Telegram bot token is used. Set a stable value in production.
PUBLIC_BASE_URL=
INTERVIEW_TOKEN_SECRET=
